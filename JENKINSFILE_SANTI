                            timeout /t 15
                            set PYTHONPATH=%WORKSPACE%
                            pytest --junitxml=result-rest.xml test\\rest
                        '''
                        */
                    }
                }
            }
        }



        stage('Result') {
            steps {
                // Este comando es nativo de Jenkins, funciona igual en Mac y Windows
                junit 'result*.xml' 
                // Windows: (Igual que arriba) junit 'result*.xml'
            }
        }
    
    }
}
