pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                // Get some code from a GitHub repository
                git 'https://github.com/santt3131/devops_caso1.1.git'
              
            }

        }
        
        stage('Build') {
            steps {
                echo 'Eyyyyy, esto es Python. No hay que compilar nada!!!'
                // Mantenemos WORKSPACE tal cual lo tenías
                echo WORKSPACE
                sh 'ls' 
                //Window: bat 'dir'
            }
        }

     

        stage('Test'){
            parallel{
                stage('Unit') {
                    steps {
                        // En Mac usamos 'sh' y barras inclinadas /
                        sh '''
                            export PYTHONPATH=WORKSPACE
                            python3 -m pytest --junitxml=result-unit.xml test/unit
                        '''
